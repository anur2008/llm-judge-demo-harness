# Copy to .env and fill in values, then export before running:
#   cp .env.example .env
#   set -a && source .env && set +a
#
# Or pass overrides on the command line: --model ID --region R

# Same profile used by automated-tests-v1 (see .robot.local.sh: AWS_PROFILE arg)
AWS_PROFILE=int

# Bedrock region for the int account (matches automated-tests-v1 / bedrockutils.py)
AWS_REGION=us-west-2

# Bedrock model ID (inference profile or on-demand model ID from the console)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
